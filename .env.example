APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Realtime / WebSocket (Laravel Reverb).
# WAJIB diisi sebelum `npm run build` — var VITE_REVERB_* ditanam ke bundle saat
# build. Kalau VITE_REVERB_APP_KEY kosong, fitur realtime nonaktif (lihat echo.js).
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Bind server Reverb (proses `php artisan reverb:start`).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Tujuan broadcasting client sisi server (PHP -> Reverb). Lokal: localhost:8080 http.
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
# Sisi browser. PRODUKSI: set ke domain publik + 443 + https (di-proxy nginx ke
# REVERB_SERVER_PORT). Jangan interpolasi dari REVERB_HOST kalau beda dgn server.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Geocoding - default menunjuk instance self-hosted Nominatim (lihat docker/nominatim/).
# Sengaja BUKAN server publik agar konfigurasi salah gagal cepat, bukan diam-diam pukul publik.
NOMINATIM_BASE_URL=http://127.0.0.1:8080
NOMINATIM_USER_AGENT="SISUPIT-Damkar/1.0 (admin@sisupit.test)"

# Routing rute jalan - default menunjuk instance self-hosted OSRM (lihat docker/osrm/).
OSRM_BASE_URL=http://127.0.0.1:5000
OSRM_USER_AGENT="SISUPIT-Damkar/1.0 (admin@sisupit.test)"

# Basemap tiles (peta Leaflet) - ditarik langsung oleh BROWSER. Kosongkan = default CARTO Voyager
# (turunan OpenStreetMap). Set ke tile server sendiri untuk self-host penuh (lihat docker/, pola OSRM).
# MAP_TILE_URL=
