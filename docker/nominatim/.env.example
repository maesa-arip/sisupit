# Nama file PBF yang sudah di-download, ditaruh di docker/nominatim/data/
PBF_FILENAME=indonesia-latest.osm.pbf

# Ganti dengan password acak yang kuat sebelum deploy ke VPS.
NOMINATIM_PASSWORD=changeme

# Sesuaikan dengan jumlah vCPU VPS (mis. 4 untuk VPS 4 core).
NOMINATIM_THREADS=4

# Port di host VPS yang akan diteruskan ke Nominatim (container selalu listen di 8080).
NOMINATIM_HOST_PORT=8080
